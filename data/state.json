    {
      "id": "song-1",
      "title": "Bapa Engkau Sungguh Baik",
      "artist": "Symphony Worship",
      "key": "G",
      "sections": [
        {
          "type": "V1",
          "label": "Verse 1",
          "lines": [
            "Bapa Engkau sungguh baik",
            "KasihMu nyata dalam hidupku"
          ]
        },
        {
          "type": "CH",
          "label": "Chorus",
          "lines": [
            "Haleluya, kami memujiMu",
            "Haleluya, selamanya"
          ]
        },
        {
          "type": "V2",
          "label": "Verse 2",
          "lines": [
            "Dalam segala keadaan",
            "TanganMu yang menopangku"
          ]
        },
        {
          "type": "BR",
          "label": "Bridge",
          "lines": [
            "Kemuliaan bagiMu Tuhan",
            "Selama-lamanya"
          ]
        }
      ]
    },
    {
      "id": "song-2",
      "title": "Kaulah Segalanya",
      "artist": "JPCC Worship",
      "key": "D",
      "sections": [
        {
          "type": "V1",
          "label": "Verse 1",
          "lines": [
            "Kau dan aku adalah satu",
            "Di dalam kasih Tuhan kita berdiri"
          ]
        },
        {
          "type": "CH",
          "label": "Chorus",
          "lines": [
            "Kaulah segalanya dalam hidupku",
            "Penolongku yang setia saat kubutuh"
          ]
        }
      ]
    },
    {
      "id": "song-3",
      "title": "Amazing Grace",
      "artist": "John Newton",
      "key": "C",
      "sections": [
        {
          "type": "V1",
          "label": "Verse 1",
          "lines": [
            "Amazing grace, how sweet the sound",
            "That saved a wretch like me"
          ]
        },
        {
          "type": "V2",
          "label": "Verse 2",
          "lines": [
            "I once was lost, but now am found",
            "Was blind, but now I see"
          ]
        }
      ]
    }
  ],
